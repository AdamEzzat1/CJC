// Vizor Example: Line Plot
// Demonstrates: geom_line, annotations, theme_minimal

import vizor

let x = [0.0, 0.5, 1.0, 1.5, 2.0, 2.5, 3.0];
let y = [0.0, 0.25, 1.0, 2.25, 4.0, 6.25, 9.0];

let p = vizor_plot(x, y);
let p = p.geom_line();
let p = p.title("Quadratic Curve: y = x^2");
let p = p.xlab("x");
let p = p.ylab("y");
let p = p.theme_minimal();

p.save("line_output.svg");
print("Line plot saved to line_output.svg");
